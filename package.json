{
  "name": "becmi-foundry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Lightweight test and lint tooling for the FoundryVTT BECMI system.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "extract:spells": "node scripts/extract-spells.mjs",
    "review:spells": "node scripts/review-spells.mjs",
    "build:spells": "node scripts/build-spells.mjs",
    "validate:spells": "node scripts/validate-spells.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "eslint": "^9.27.0",
    "globals": "^15.15.0",
    "vitest": "^2.1.8"
  }
}

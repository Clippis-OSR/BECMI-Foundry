<form class="{{cssClass}}" autocomplete="off">

  <h1>{{actor.name}}</h1>

<nav class="sheet-tabs tabs" data-group="primary">
  <a class="item active" data-tab="main">Main</a>
  <a class="item" data-tab="combat">Combat</a>
  <a class="item" data-tab="equipment">Equipment</a>
  <a class="item" data-tab="skills">Skills</a>
  <a class="item" data-tab="magic">Magic</a>
  <a class="item" data-tab="cleric">Cleric</a>
</nav>

<section class="sheet-body">

<div class="tab active" data-group="primary" data-tab="main"></div>

<div class="tab" data-group="primary" data-tab="main">
  <h2>Details</h2>
  <div>Class: <select name="system.class">
    <option value="fighter" {{#if (eq system.class "fighter")}}selected{{/if}}>Fighter</option>
    <option value="cleric" {{#if (eq system.class "cleric")}}selected{{/if}}>Cleric</option>
    <option value="magic-user" {{#if (eq system.class "magic-user")}}selected{{/if}}>Magic-User</option>
    <option value="thief" {{#if (eq system.class "thief")}}selected{{/if}}>Thief</option>
    <option value="dwarf" {{#if (eq system.class "dwarf")}}selected{{/if}}>Dwarf</option>
    <option value="elf" {{#if (eq system.class "elf")}}selected{{/if}}>Elf</option>
    <option value="halfling" {{#if (eq system.class "halfling")}}selected{{/if}}>Halfling</option>
  </select></div>
  <div>Level: {{system.derived.level}}</div>
  <input type="hidden" name="system.level" value="{{system.level}}" />
  <div>XP: <input type="number" name="system.experience.current" value="{{system.experience.current}}" /></div>
  <div>Alignment: <input type="text" name="system.details.alignment" value="{{system.details.alignment}}" /></div>

  <hr>

  <h2>Abilities</h2>

<div>
  <button type="button" class="roll-ability" data-ability="str" data-label="Strength">Roll</button>
  STR:
  <input type="number" name="system.abilities.str.value" value="{{system.abilities.str.value}}" />
  / Mod:
  <input type="number" name="system.abilities.str.mod" value="{{system.abilities.str.mod}}" />
</div>

<div>
  <button type="button" class="roll-ability" data-ability="int" data-label="Intelligence">Roll</button>
  INT:
  <input type="number" name="system.abilities.int.value" value="{{system.abilities.int.value}}" />
  / Mod:
  <input type="number" name="system.abilities.int.mod" value="{{system.abilities.int.mod}}" />
</div>

<div>
  <button type="button" class="roll-ability" data-ability="wis" data-label="Wisdom">Roll</button>
  WIS:
  <input type="number" name="system.abilities.wis.value" value="{{system.abilities.wis.value}}" />
  / Mod:
  <input type="number" name="system.abilities.wis.mod" value="{{system.abilities.wis.mod}}" />
</div>

<div>
  <button type="button" class="roll-ability" data-ability="dex" data-label="Dexterity">Roll</button>
  DEX:
  <input type="number" name="system.abilities.dex.value" value="{{system.abilities.dex.value}}" />
  / Mod:
  <input type="number" name="system.abilities.dex.mod" value="{{system.abilities.dex.mod}}" />
</div>

<div>
  <button type="button" class="roll-ability" data-ability="con" data-label="Constitution">Roll</button>
  CON:
  <input type="number" name="system.abilities.con.value" value="{{system.abilities.con.value}}" />
  / Mod:
  <input type="number" name="system.abilities.con.mod" value="{{system.abilities.con.mod}}" />
</div>

<div>
  <button type="button" class="roll-ability" data-ability="cha" data-label="Charisma">Roll</button>
  CHA:
  <input type="number" name="system.abilities.cha.value" value="{{system.abilities.cha.value}}" />
  / Mod:
  <input type="number" name="system.abilities.cha.mod" value="{{system.abilities.cha.mod}}" />
</div>
  <hr>

  <h2>Languages Known</h2>
  <textarea name="system.languages" rows="3">{{system.languages}}</textarea>

  <hr>

  <h2>Special Abilities</h2>
  <textarea name="system.specialAbilities" rows="5">{{system.specialAbilities}}</textarea>

  </div>
<div class="tab" data-group="primary" data-tab="combat">
  <hr>

<h2>Combat</h2>

<div>
  AC:
  <input type="number" name="system.ac.value" value="{{system.ac.value}}" readonly />
  <div><small>Base: {{system.ac.base}}</small></div>
  {{#if system.ac.breakdown.length}}<details><summary>AC Breakdown</summary><ul>{{#each system.ac.breakdown as |part|}}<li>{{part.label}} {{#if part.value}}: {{part.value}}{{/if}}{{#if part.modifier}} ({{part.modifier}}){{/if}}</li>{{/each}}</ul></details>{{/if}}
</div>

<div>
  THAC0:
  <span>{{actor.system.derived.thac0}}</span>
</div>

<div>
  Initiative Modifier:
  <input type="number" name="system.combat.initiative" value="{{system.combat.initiative}}" />
  <button type="button" class="roll-initiative">Roll Initiative</button>
</div>

<div>
  Wrestling Rating:
  <input type="number" name="system.combat.wrestlingRating" value="{{system.combat.wrestlingRating}}" />
</div>

<div>
  HP:
  <input type="number" name="system.hp.value" value="{{system.hp.value}}" />
  /
  <input type="number" name="system.hp.max" value="{{system.hp.max}}" />
</div>

<div>
  Wounds:
  <input type="number" name="system.hp.wounds" value="{{system.hp.wounds}}" />
</div>

<hr>

<h2>Attacks</h2>

<h3>Equipped Weapon Attacks</h3>
{{#if combat.weaponAttacks.length}}
<table>
  <thead>
    <tr>
      <th>Roll</th>
      <th>Weapon</th>
      <th>Type</th>
      <th>Damage</th>
      <th>Damage Types</th>
    </tr>
  </thead>
  <tbody>
    {{#each combat.weaponAttacks as |attack|}}
    <tr>
      <td>
        <button type="button" class="becmi-weapon-attack" data-item-id="{{attack.itemId}}">Attack</button>
      </td>
      <td>{{attack.name}}</td>
      <td>{{attack.type}}</td>
      <td>{{attack.damage}}</td>
      <td>
        {{#if attack.damageTypes.length}}
          {{#each attack.damageTypes as |tag idx|}}{{#if idx}}, {{/if}}{{tag}}{{/each}}
        {{else}}-{{/if}}
      </td>
    </tr>
    {{/each}}
  </tbody>
</table>
{{else}}
<p>No equipped weapons.</p>
{{/if}}


<hr>

<h2>Saving Throws</h2>

<div>
  <button type="button" class="roll-save" data-save-type="deathRayPoison" data-label="Death Ray / Poison">
    Roll
  </button>
  Death Ray / Poison:
  <span>{{actor.system.saves.deathRayPoison.value}}</span>
</div>

<div>
  <button type="button" class="roll-save" data-save-type="magicWands" data-label="Magic Wands">
    Roll
  </button>
  Magic Wands:
  <span>{{actor.system.saves.magicWands.value}}</span>
</div>

<div>
  <button type="button" class="roll-save" data-save-type="paralysisTurnStone" data-label="Paralysis / Turn to Stone">
    Roll
  </button>
  Paralysis / Turn to Stone:
  <span>{{actor.system.saves.paralysisTurnStone.value}}</span>
</div>

<div>
  <button type="button" class="roll-save" data-save-type="dragonBreath" data-label="Dragon Breath">
    Roll
  </button>
  Dragon Breath:
  <span>{{actor.system.saves.dragonBreath.value}}</span>
</div>

<div>
  <button type="button" class="roll-save" data-save-type="rodStaffSpell" data-label="Rod / Staff / Spell">
    Roll
  </button>
  Rod / Staff / Spell:
  <span>{{actor.system.saves.rodStaffSpell.value}}</span>
</div>

<h2>Weapon Mastery</h2>

<table>
  <thead>
    <tr>
      <th>Weapon</th>
      <th>Level</th>
      <th>Damage</th>
      <th>Range</th>
      <th>Defense</th>
      <th>Special</th>
    </tr>
  </thead>
  <tbody>
    {{#each system.weaponMastery as |wm i|}}
    <tr>
      <td><input type="text" name="system.weaponMastery.{{i}}.weapon" value="{{wm.weapon}}" /></td>
      <td><input type="text" name="system.weaponMastery.{{i}}.level" value="{{wm.level}}" /></td>
      <td><input type="text" name="system.weaponMastery.{{i}}.damage" value="{{wm.damage}}" /></td>
      <td><input type="text" name="system.weaponMastery.{{i}}.range" value="{{wm.range}}" /></td>
      <td><input type="text" name="system.weaponMastery.{{i}}.defense" value="{{wm.defense}}" /></td>
      <td><input type="text" name="system.weaponMastery.{{i}}.special" value="{{wm.special}}" /></td>
    </tr>
    {{/each}}
  </tbody>
</table>
</div>

<div class="tab" data-group="primary" data-tab="skills">
<hr>

<h2>General Skill Mastery</h2>
<table>
  <thead>
    <tr>
      <th>Skill</th>
      <th>Ability</th>
      <th>Score</th>
      <th>Notes</th>
    </tr>
  </thead>
  <tbody>
    {{#each system.generalSkills as |skill i|}}
    <tr>
      <td><input type="text" name="system.generalSkills.{{i}}.name" value="{{skill.name}}" /></td>
      <td><input type="text" name="system.generalSkills.{{i}}.ability" value="{{skill.ability}}" /></td>
      <td><input type="number" name="system.generalSkills.{{i}}.score" value="{{skill.score}}" /></td>
      <td><input type="text" name="system.generalSkills.{{i}}.notes" value="{{skill.notes}}" /></td>
    </tr>
    {{/each}}
  </tbody>
</table>

    {{#if system.derived.hasThiefSkills}}
    <h2>Thief Skills</h2>

<div>
  <button type="button" class="roll-thief-skill" data-skill="openLocks" data-label="Open Locks">Roll</button>
  Open Locks:
  <span>{{system.derived.thiefSkills.openLocks}}</span> %
</div>

<div>
  <button type="button" class="roll-thief-skill" data-skill="findRemoveTraps" data-label="Find/Remove Traps">Roll</button>
  Find/Remove Traps:
  <span>{{system.derived.thiefSkills.findRemoveTraps}}</span> %
</div>

<div>
  <button type="button" class="roll-thief-skill" data-skill="climbWalls" data-label="Climb Walls">Roll</button>
  Climb Walls:
  <span>{{system.derived.thiefSkills.climbWalls}}</span> %
</div>

<div>
  <button type="button" class="roll-thief-skill" data-skill="moveSilently" data-label="Move Silently">Roll</button>
  Move Silently:
  <span>{{system.derived.thiefSkills.moveSilently}}</span> %
</div>

<div>
  <button type="button" class="roll-thief-skill" data-skill="hideInShadows" data-label="Hide in Shadows">Roll</button>
  Hide in Shadows:
  <span>{{system.derived.thiefSkills.hideInShadows}}</span> %
</div>

<div>
  <button type="button" class="roll-thief-skill" data-skill="pickPockets" data-label="Pick Pockets">Roll</button>
  Pick Pockets:
  <span>{{system.derived.thiefSkills.pickPockets}}</span> %
</div>

<div>
  <button type="button" class="roll-thief-skill" data-skill="hearNoise" data-label="Hear Noise">Roll</button>
  Hear Noise:
  <span>{{system.derived.thiefSkills.hearNoise}}</span> %
</div>
{{/if}}
</div>

<div class="tab" data-group="primary" data-tab="equipment">

<h2>Inventory & Encumbrance</h2>

<section class="inventory-section">
  <h3>Coinage</h3>
  <table>
    <thead><tr><th>Type</th><th>Carried</th><th>Treasure Horde</th></tr></thead>
    <tbody>
      {{#each currencySummary.rows as |coin|}}
      <tr>
        <td>{{coin.denomination}}</td>
        <td><input type="number" name="system.currency.carried.{{coin.denomination}}" value="{{coin.carriedQuantity}}" min="0" step="1" /></td>
        <td><input type="number" name="system.currency.treasureHorde.{{coin.denomination}}" value="{{coin.treasureHordeQuantity}}" min="0" step="1" /></td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</section>

<section class="inventory-section">
  <h3>Treasure</h3>
  <div><strong>Items:</strong> {{treasureSummary.count}} | <strong>Total:</strong> {{treasureSummary.totalValue}} gp</div>
  <label for="treasure-notes">Notes</label>
  <textarea id="treasure-notes" name="system.treasure.notes" rows="3">{{system.treasure.notes}}</textarea>
</section>

<section class="inventory-section">
  <h3>Encumbrance & Movement (Derived)</h3>
  <div class="enc-grid">
    <div><strong>Total Encumbrance Carried:</strong> {{encumbranceSummary.total}} cn</div>
    <div><strong>Without Backpack:</strong> {{encumbranceSummary.withoutBackpack}} cn</div>
    <div><strong>Without Sacks:</strong> {{encumbranceSummary.withoutSacks}} cn</div>
    <div><strong>Only Belt Pouch & Items Worn:</strong> {{encumbranceSummary.beltPouchAndWorn}} cn</div>
    <div><strong>Normal Speed:</strong> {{encumbranceSummary.normalSpeed}} feet/turn</div>
    <div><strong>Encounter Speed:</strong> {{encumbranceSummary.encounterSpeed}} feet/round</div>
  </div>
</section>

{{#each inventoryGroups as |group|}}
<section class="inventory-group inventory-section inventory-drop-zone" data-location="{{group.sectionLocation}}">
  <div class="inventory-section-header"><h3>{{group.label}}</h3><span>{{group.containedWeight}} cn</span></div>
  <table>
    <thead><tr><th>Name</th><th>Qty</th><th>Enc</th><th>Total Enc</th><th>Location</th><th>Controls</th></tr></thead>
    <tbody>
    {{#if group.items.length}}
      {{#each group.items as |item|}}
      <tr class="inventory-item-row">
        <td>{{item.name}}</td>
        <td><input type="number" value="{{item.quantity}}" min="0" step="1" data-action="update-inventory-item" data-item-id="{{item.id}}" data-field="system.quantity" /></td>
        <td><input type="number" value="{{item.weight}}" step="0.01" data-action="update-inventory-item" data-item-id="{{item.id}}" data-field="system.weight" /></td>
        <td>{{item.totalWeight}}</td>
        <td>
          <select data-action="update-inventory-item" data-item-id="{{item.id}}" data-field="system.inventory.location">
            <option value="beltPouch" {{#if (eq item.location "beltPouch")}}selected{{/if}}>Belt Pouch</option>
            <option value="worn" {{#if (eq item.location "worn")}}selected{{/if}}>Worn</option>
            <option value="backpack" {{#if (eq item.location "backpack")}}selected{{/if}}>Backpack</option>
            <option value="sack1" {{#if (eq item.location "sack1")}}selected{{/if}}>Sack #1</option>
            <option value="sack2" {{#if (eq item.location "sack2")}}selected{{/if}}>Sack #2</option>
          </select>
        </td>
        <td><button type="button" data-action="item-edit" data-item-id="{{item.id}}">Edit</button> <button type="button" data-action="item-delete" data-item-id="{{item.id}}">Delete</button></td>
      </tr>
      {{/each}}
    {{else}}
      <tr><td colspan="6"><em>No items.</em></td></tr>
    {{/if}}
    </tbody>
  </table>
</section>
{{/each}}

</div>

{{#if system.derived.hasSpellcasting}}
<div class="tab" data-group="primary" data-tab="magic">
<hr>
<h2>Spellcasting</h2>
{{#each spellcastingDerived as |casterData casterKey|}}
  {{#if casterData.enabled}}
  <section>
    <h3>{{casterKey}}</h3>
    <div>{{casterData.summaryLabel}}</div>
    {{#each casterData.slots as |slot level|}}
      <div><strong>Level {{level}}:</strong> {{slot.used}} / {{slot.max}} used ({{slot.remaining}} remaining)</div>
    {{/each}}
    {{#with (lookup ../spellcasting.casters casterKey) as |caster|}}
      {{#if caster.known}}
      <h4>Known</h4>
      {{#each caster.known as |entries level|}}
        <div><strong>L{{level}}:</strong>
          {{#if entries.length}}{{#each entries as |ref|}}<span>{{ref.spellKey}}</span> {{/each}}{{else}}<em>None</em>{{/if}}
        </div>
      {{/each}}
      {{/if}}
      <h4>Prepared</h4>
      {{#each caster.prepared as |entries level|}}
        <div><strong>L{{level}}:</strong>
          {{#if entries.length}}{{#each entries as |ref|}}<span>{{ref.spellKey}}</span> {{/each}}{{else}}<em>None</em>{{/if}}
        </div>
      {{/each}}
    {{/with}}
  </section>
  {{/if}}
{{/each}}
</div>
{{/if}}

{{#if system.derived.hasTurnUndead}}
<div class="tab" data-group="primary" data-tab="cleric">
<hr>

<h2>Turn Undead (Derived)</h2>
<div>
  <label for="turn-undead-target">Undead Type:</label>
  <select id="turn-undead-target" data-action="turn-undead-target">
    {{#each turnUndeadList}}
      <option value="{{this.target}}">{{this.target}}</option>
    {{/each}}
  </select>
  <button type="button" class="roll-turn-undead">Roll Turn Undead</button>
</div>
<table>
  <thead>
    <tr>
      <th>Target</th>
      <th>Score</th>
    </tr>
  </thead>
  <tbody>
    {{#each turnUndeadList}}
    <tr>
      <td>{{this.target}}</td>
      <td>{{this.score}}</td>
    </tr>
    {{/each}}
  </tbody>
</table>
</div>
{{/if}}

 </section>

</form>

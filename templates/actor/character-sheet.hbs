<form class="{{cssClass}}" autocomplete="off">

  <h1>{{actor.name}}</h1>

<nav class="sheet-tabs tabs" data-group="primary">
  <a class="item active" data-tab="main">Main</a>
  <a class="item" data-tab="combat">Combat</a>
  <a class="item" data-tab="equipment">Equipment</a>
  <a class="item" data-tab="skills">Skills</a>
  <a class="item" data-tab="magic">Magic</a>
  <a class="item" data-tab="cleric">Cleric</a>
</nav>

<section class="sheet-body">

<div class="tab active" data-group="primary" data-tab="main"></div>

<div class="tab" data-group="primary" data-tab="main">
  <h2>Details</h2>
  <div>Class: <select name="system.class">
    <option value="fighter" {{#if (eq system.class "fighter")}}selected{{/if}}>Fighter</option>
    <option value="cleric" {{#if (eq system.class "cleric")}}selected{{/if}}>Cleric</option>
    <option value="magic-user" {{#if (eq system.class "magic-user")}}selected{{/if}}>Magic-User</option>
    <option value="thief" {{#if (eq system.class "thief")}}selected{{/if}}>Thief</option>
    <option value="dwarf" {{#if (eq system.class "dwarf")}}selected{{/if}}>Dwarf</option>
    <option value="elf" {{#if (eq system.class "elf")}}selected{{/if}}>Elf</option>
    <option value="halfling" {{#if (eq system.class "halfling")}}selected{{/if}}>Halfling</option>
  </select></div>
  <div>Level: {{system.derived.level}}</div>
  <input type="hidden" name="system.level" value="{{system.level}}" />
  <div>XP: <input type="number" name="system.experience.current" value="{{system.experience.current}}" /></div>
  <div>Alignment: <input type="text" name="system.details.alignment" value="{{system.details.alignment}}" /></div>

  <hr>

  <h2>Abilities</h2>

<div>
  <button type="button" class="roll-ability" data-ability="str" data-label="Strength">Roll</button>
  STR:
  <input type="number" name="system.abilities.str.value" value="{{system.abilities.str.value}}" />
  / Mod:
  <input type="number" name="system.abilities.str.mod" value="{{system.abilities.str.mod}}" />
</div>

<div>
  <button type="button" class="roll-ability" data-ability="int" data-label="Intelligence">Roll</button>
  INT:
  <input type="number" name="system.abilities.int.value" value="{{system.abilities.int.value}}" />
  / Mod:
  <input type="number" name="system.abilities.int.mod" value="{{system.abilities.int.mod}}" />
</div>

<div>
  <button type="button" class="roll-ability" data-ability="wis" data-label="Wisdom">Roll</button>
  WIS:
  <input type="number" name="system.abilities.wis.value" value="{{system.abilities.wis.value}}" />
  / Mod:
  <input type="number" name="system.abilities.wis.mod" value="{{system.abilities.wis.mod}}" />
</div>

<div>
  <button type="button" class="roll-ability" data-ability="dex" data-label="Dexterity">Roll</button>
  DEX:
  <input type="number" name="system.abilities.dex.value" value="{{system.abilities.dex.value}}" />
  / Mod:
  <input type="number" name="system.abilities.dex.mod" value="{{system.abilities.dex.mod}}" />
</div>

<div>
  <button type="button" class="roll-ability" data-ability="con" data-label="Constitution">Roll</button>
  CON:
  <input type="number" name="system.abilities.con.value" value="{{system.abilities.con.value}}" />
  / Mod:
  <input type="number" name="system.abilities.con.mod" value="{{system.abilities.con.mod}}" />
</div>

<div>
  <button type="button" class="roll-ability" data-ability="cha" data-label="Charisma">Roll</button>
  CHA:
  <input type="number" name="system.abilities.cha.value" value="{{system.abilities.cha.value}}" />
  / Mod:
  <input type="number" name="system.abilities.cha.mod" value="{{system.abilities.cha.mod}}" />
</div>
  <hr>

  <h2>Languages Known</h2>
  <textarea name="system.languages" rows="3">{{system.languages}}</textarea>

  <hr>

  <h2>Special Abilities</h2>
  <textarea name="system.specialAbilities" rows="5">{{system.specialAbilities}}</textarea>

  </div>
<div class="tab" data-group="primary" data-tab="combat">
  <hr>

<h2>Combat</h2>

<div>
  AC:
  <input type="number" name="system.combat.ac" value="{{system.combat.ac}}" />
</div>

<div>
  THAC0:
  <span>{{actor.system.derived.thac0}}</span>
</div>

<div>
  Initiative Modifier:
  <input type="number" name="system.combat.initiative" value="{{system.combat.initiative}}" />
  <button type="button" class="roll-initiative">Roll Initiative</button>
</div>

<div>
  Wrestling Rating:
  <input type="number" name="system.combat.wrestlingRating" value="{{system.combat.wrestlingRating}}" />
</div>

<div>
  HP:
  <input type="number" name="system.hp.value" value="{{system.hp.value}}" />
  /
  <input type="number" name="system.hp.max" value="{{system.hp.max}}" />
</div>

<div>
  Wounds:
  <input type="number" name="system.hp.wounds" value="{{system.hp.wounds}}" />
</div>

<hr>

<h2>Attacks</h2>

<table>
  <thead>
    <tr>
      <th>Roll</th>
      <th>Name</th>
      <th>Attack Mod</th>
      <th>Damage</th>
      <th>Damage Mod</th>
      <th>Remove</th>
    </tr>
  </thead>
  <tbody>
    {{#each attacks as |attack index|}}
    <tr>
      <td>
        <button type="button" data-action="roll-character-attack" data-index="{{index}}">
          Attack
        </button>
      </td>
      <td>
        <input type="text" name="attack-name-{{index}}" value="{{attack.name}}" data-action="change-character-attack-field" data-index="{{index}}" data-field="name" />
      </td>
      <td>
        <input type="number" name="attack-mod-{{index}}" value="{{attack.attackMod}}" data-action="change-character-attack-field" data-index="{{index}}" data-field="attackMod" />
      </td>
      <td>
        <input type="text" name="attack-damage-{{index}}" value="{{attack.damage}}" data-action="change-character-attack-field" data-index="{{index}}" data-field="damage" />
      </td>
      <td>
        <input type="number" name="attack-damage-mod-{{index}}" value="{{attack.damageMod}}" data-action="change-character-attack-field" data-index="{{index}}" data-field="damageMod" />
      </td>
      <td>
        <button type="button" data-action="remove-character-attack" data-index="{{index}}">Remove</button>
      </td>
    </tr>
    {{/each}}
  </tbody>
</table>

<button type="button" data-action="add-character-attack">Add Attack</button>

<hr>

<h2>Saving Throws</h2>

<div>
  <button type="button" class="roll-save" data-save="death" data-label="Death Ray / Poison">
    Roll
  </button>
  Death Ray / Poison:
  <span>{{actor.system.derived.saves.death}}</span>
</div>

<div>
  <button type="button" class="roll-save" data-save="wands" data-label="Magic Wands">
    Roll
  </button>
  Magic Wands:
  <span>{{actor.system.derived.saves.wands}}</span>
</div>

<div>
  <button type="button" class="roll-save" data-save="paralysis" data-label="Paralysis / Turn to Stone">
    Roll
  </button>
  Paralysis / Turn to Stone:
  <span>{{actor.system.derived.saves.paralysis}}</span>
</div>

<div>
  <button type="button" class="roll-save" data-save="breath" data-label="Dragon Breath">
    Roll
  </button>
  Dragon Breath:
  <span>{{actor.system.derived.saves.breath}}</span>
</div>

<div>
  <button type="button" class="roll-save" data-save="spells" data-label="Rod, Staff, or Spell">
    Roll
  </button>
  Rod, Staff, or Spell:
  <span>{{actor.system.derived.saves.spells}}</span>
</div>

<h2>Weapon Mastery</h2>

<table>
  <thead>
    <tr>
      <th>Weapon</th>
      <th>Level</th>
      <th>Damage</th>
      <th>Range</th>
      <th>Defense</th>
      <th>Special</th>
    </tr>
  </thead>
  <tbody>
    {{#each system.weaponMastery as |wm i|}}
    <tr>
      <td><input type="text" name="system.weaponMastery.{{i}}.weapon" value="{{wm.weapon}}" /></td>
      <td><input type="text" name="system.weaponMastery.{{i}}.level" value="{{wm.level}}" /></td>
      <td><input type="text" name="system.weaponMastery.{{i}}.damage" value="{{wm.damage}}" /></td>
      <td><input type="text" name="system.weaponMastery.{{i}}.range" value="{{wm.range}}" /></td>
      <td><input type="text" name="system.weaponMastery.{{i}}.defense" value="{{wm.defense}}" /></td>
      <td><input type="text" name="system.weaponMastery.{{i}}.special" value="{{wm.special}}" /></td>
    </tr>
    {{/each}}
  </tbody>
</table>
</div>

<div class="tab" data-group="primary" data-tab="skills">
<hr>

<h2>General Skill Mastery</h2>
<table>
  <thead>
    <tr>
      <th>Skill</th>
      <th>Ability</th>
      <th>Score</th>
      <th>Notes</th>
    </tr>
  </thead>
  <tbody>
    {{#each system.generalSkills as |skill i|}}
    <tr>
      <td><input type="text" name="system.generalSkills.{{i}}.name" value="{{skill.name}}" /></td>
      <td><input type="text" name="system.generalSkills.{{i}}.ability" value="{{skill.ability}}" /></td>
      <td><input type="number" name="system.generalSkills.{{i}}.score" value="{{skill.score}}" /></td>
      <td><input type="text" name="system.generalSkills.{{i}}.notes" value="{{skill.notes}}" /></td>
    </tr>
    {{/each}}
  </tbody>
</table>

    {{#if system.derived.hasThiefSkills}}
    <h2>Thief Skills</h2>

<div>
  <button type="button" class="roll-thief-skill" data-skill="openLocks" data-label="Open Locks">Roll</button>
  Open Locks:
  <span>{{system.derived.thiefSkills.openLocks}}</span> %
</div>

<div>
  <button type="button" class="roll-thief-skill" data-skill="findTraps" data-label="Find Traps">Roll</button>
  Find Traps:
  <span>{{system.derived.thiefSkills.findTraps}}</span> %
</div>

<div>
  <button type="button" class="roll-thief-skill" data-skill="removeTraps" data-label="Remove Traps">Roll</button>
  Remove Traps:
  <span>{{system.derived.thiefSkills.removeTraps}}</span> %
</div>

<div>
  <button type="button" class="roll-thief-skill" data-skill="climbWalls" data-label="Climb Walls">Roll</button>
  Climb Walls:
  <span>{{system.derived.thiefSkills.climbWalls}}</span> %
</div>

<div>
  <button type="button" class="roll-thief-skill" data-skill="moveSilently" data-label="Move Silently">Roll</button>
  Move Silently:
  <span>{{system.derived.thiefSkills.moveSilently}}</span> %
</div>

<div>
  <button type="button" class="roll-thief-skill" data-skill="hideInShadows" data-label="Hide in Shadows">Roll</button>
  Hide in Shadows:
  <span>{{system.derived.thiefSkills.hideInShadows}}</span> %
</div>

<div>
  <button type="button" class="roll-thief-skill" data-skill="pickPockets" data-label="Pick Pockets">Roll</button>
  Pick Pockets:
  <span>{{system.derived.thiefSkills.pickPockets}}</span> %
</div>

<div>
  <button type="button" class="roll-thief-skill" data-skill="hearNoise" data-label="Hear Noise">Roll</button>
  Hear Noise:
  <span>{{system.derived.thiefSkills.hearNoise}}</span> %
</div>
{{/if}}
</div>

<div class="tab" data-group="primary" data-tab="equipment">

<hr>

<h2>Currency</h2>
<table>
  <thead>
    <tr>
      <th>Denomination</th>
      <th>Quantity</th>
      <th>Value (gp)</th>
      <th>Weight (cn)</th>
    </tr>
  </thead>
  <tbody>
    {{#each currencySummary.rows as |coin|}}
    <tr>
      <td>{{coin.denomination}}</td>
      <td>
        <input type="number" value="{{coin.quantity}}" min="0" step="1" data-action="change-currency-quantity" data-denomination="{{coin.denomination}}" />
      </td>
      <td>{{coin.valueGp}}</td>
      <td>{{coin.weightCn}}</td>
    </tr>
    {{/each}}
  </tbody>
</table>
<div><strong>Total currency value:</strong> {{currencySummary.totalValueGp}} gp</div>
<div><strong>Total currency weight:</strong> {{currencySummary.totalWeightCn}} cn</div>

<hr>

<h2>Treasure</h2>
<div><strong>Treasure items:</strong> {{treasureSummary.count}}</div>
<div><strong>Treasure value:</strong> {{treasureSummary.totalValue}} gp</div>
<div><strong>Identified treasure value:</strong> {{treasureSummary.identifiedValue}} gp</div>
<div><strong>Carried treasure weight:</strong> {{treasureSummary.totalWeight}} cn</div>

<section class="inventory-group inventory-section inventory-drop-zone" data-location="treasure">
<div class="inventory-section-header">
  <h3>{{treasureGroup.sectionSummary}}</h3>
</div>
<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Treasure Type</th>
      <th>Qty</th>
      <th>Wt</th>
      <th>Total Wt</th>
      <th>Value</th>
      <th>Est. Value</th>
      <th>Identified</th>
      <th>Location</th>
      <th>Controls</th>
    </tr>
  </thead>
  <tbody>
    {{#if treasureGroup.items.length}}
      {{#each treasureGroup.items as |item|}}
      <tr class="inventory-item-row {{#if (eq item.location "storage")}}item-in-storage{{/if}}">
        <td><input type="text" value="{{item.name}}" data-action="update-inventory-item" data-item-id="{{item.id}}" data-field="name" /></td>
        <td>{{item.treasureType}}</td>
        <td><input type="number" value="{{item.quantity}}" min="0" step="1" data-action="update-inventory-item" data-item-id="{{item.id}}" data-field="system.quantity" /></td>
        <td><input type="number" value="{{item.weight}}" step="0.01" data-action="update-inventory-item" data-item-id="{{item.id}}" data-field="system.weight" /></td>
        <td>{{item.totalWeight}}</td>
        <td><input type="number" value="{{item.value}}" step="0.01" data-action="update-inventory-item" data-item-id="{{item.id}}" data-field="system.value" /></td>
        <td><input type="number" value="{{item.estimatedValue}}" step="0.01" data-action="update-inventory-item" data-item-id="{{item.id}}" data-field="system.estimatedValue" /></td>
        <td><input type="checkbox" {{checked item.identified}} data-action="update-inventory-item" data-item-id="{{item.id}}" data-field="system.identified" /></td>
        <td>
          <select data-action="update-inventory-item" data-item-id="{{item.id}}" data-field="system.location">
            <option value="treasure" {{#if (eq item.location "treasure")}}selected{{/if}}>Treasure</option>
            <option value="storage" {{#if (eq item.location "storage")}}selected{{/if}}>Storage</option>
          </select>
        </td>
        <td>
          <button type="button" data-action="item-edit" data-item-id="{{item.id}}">Edit</button>
          <button type="button" data-action="item-delete" data-item-id="{{item.id}}">Delete</button>
        </td>
      </tr>
      {{/each}}
    {{else}}
      <tr><td colspan="10"><em>No treasure items.</em></td></tr>
    {{/if}}
  </tbody>
</table>
<div class="inventory-drop-hint"><small>Drop item here to add to this group.</small></div>
</section>

<hr>

<h2>Encumbrance & Movement (Calculated)</h2>
<div class="encumbrance-summary">
  <div><strong>Encumbrance:</strong> {{encumbranceSummary.total}} cn — {{encumbranceSummary.bracket}} cn</div>
  <div><strong>Movement:</strong> {{encumbranceSummary.normalSpeed}}' normal / {{encumbranceSummary.encounterSpeed}}' encounter</div>
</div>

{{#if encumbranceSummary.containers.length}}
<h3>Container Encumbrance Summary</h3>
<table>
  <thead>
    <tr>
      <th>Container ID</th>
      <th>Container Wt (cn)</th>
      <th>Contents Wt (cn)</th>
      <th>Total (cn)</th>
      <th>Items</th>
    </tr>
  </thead>
  <tbody>
    {{#each encumbranceSummary.containers as |container|}}
    <tr>
      <td>{{container.containerId}}</td>
      <td>{{container.containerWeight}}</td>
      <td>{{container.contentsWeight}}</td>
      <td>{{container.total}}</td>
      <td>{{container.itemCount}}</td>
    </tr>
    {{/each}}
  </tbody>
</table>
{{/if}}

<hr>

<h2>Inventory</h2>

{{#each inventoryGroups as |group|}}
<section class="inventory-group inventory-section inventory-drop-zone" data-location="{{group.sectionLocation}}">
<div class="inventory-section-header">
  <h3>{{group.sectionSummary}}</h3>
</div>
<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Type</th>
      <th>Qty</th>
      <th>Wt</th>
      <th>Total Wt</th>
      <th>Value</th>
      <th>Location</th>
      <th>Controls</th>
    </tr>
  </thead>
  <tbody>
    {{#if group.items.length}}
      {{#each group.items as |item|}}
      <tr class="inventory-item-row">
        <td>
          <input type="text" value="{{item.name}}" data-action="update-inventory-item" data-item-id="{{item.id}}" data-field="name" />
        </td>
        <td>{{item.type}}</td>
        <td>
          <input type="number" value="{{item.quantity}}" min="0" step="1" data-action="update-inventory-item" data-item-id="{{item.id}}" data-field="system.quantity" />
        </td>
        <td>
          <input type="number" value="{{item.weight}}" step="0.01" data-action="update-inventory-item" data-item-id="{{item.id}}" data-field="system.weight" />
        </td>
        <td>{{item.totalWeight}}</td>
        <td>
          <input type="number" value="{{item.value}}" step="0.01" data-action="update-inventory-item" data-item-id="{{item.id}}" data-field="system.value" />
        </td>
        <td>
          <select data-action="update-inventory-item" data-item-id="{{item.id}}" data-field="system.location">
            <option value="equipped" {{#if (eq item.location "equipped")}}selected{{/if}}>Equipped</option>
            <option value="worn" {{#if (eq item.location "worn")}}selected{{/if}}>Worn</option>
            <option value="storage" {{#if (eq item.location "storage")}}selected{{/if}}>Storage</option>
          </select>
        </td>
        <td>
          <button type="button" data-action="item-edit" data-item-id="{{item.id}}">Edit</button>
          <button type="button" data-action="item-delete" data-item-id="{{item.id}}">Delete</button>
        </td>
      </tr>
      {{/each}}
    {{else}}
      <tr>
        <td colspan="8"><em>No items in {{group.label}}.</em></td>
      </tr>
    {{/if}}
  </tbody>
</table>
<div class="inventory-drop-hint"><small>Drop item here to add to this group.</small></div>
</section>
{{/each}}

</div>

{{#if system.derived.hasSpellcasting}}
<div class="tab" data-group="primary" data-tab="magic">
<hr>

<h2>Spell Slots (Derived)</h2>
{{#each spellSlotsList}}
<div>
  <strong>Level {{this.level}}</strong>: <span>{{this.slots}}</span>
</div>
{{/each}}

<h2>Spells Known</h2>
{{#each spellsKnownGroups as |group|}}
<section>
  <h3>Level {{group.level}}</h3>

  {{#if group.spells.length}}
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Prepared</th>
        <th>Source</th>
        <th>Notes</th>
        <th>Remove</th>
      </tr>
    </thead>
    <tbody>
      {{#each group.spells as |spell|}}
      <tr>
        <td>
          <input type="text" name="system.spellsKnown.{{group.level}}.{{spell.index}}.name" value="{{spell.name}}" />
          <input type="hidden" name="system.spellsKnown.{{group.level}}.{{spell.index}}.id" value="{{spell.id}}" />
          <input type="hidden" name="system.spellsKnown.{{group.level}}.{{spell.index}}.level" value="{{spell.level}}" />
          <input type="hidden" name="system.spellsKnown.{{group.level}}.{{spell.index}}.type" value="{{spell.type}}" />
          <input type="hidden" name="system.spellsKnown.{{group.level}}.{{spell.index}}.itemUuid" value="{{spell.itemUuid}}" />
        </td>
        <td>
          <input type="checkbox" name="system.spellsKnown.{{group.level}}.{{spell.index}}.prepared" {{checked spell.prepared}} />
        </td>
        <td>
          <span>{{spell.source}}</span>
          <input type="hidden" name="system.spellsKnown.{{group.level}}.{{spell.index}}.source" value="{{spell.source}}" />
        </td>
        <td>
          <input type="text" name="system.spellsKnown.{{group.level}}.{{spell.index}}.notes" value="{{spell.notes}}" />
        </td>
        <td>
          <button type="button" class="remove-known-spell" data-level="{{group.level}}" data-index="{{spell.index}}">Remove</button>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <p>No known spells at this level.</p>
  {{/if}}

  <button type="button" class="add-known-spell" data-level="{{group.level}}">Add Manual Spell</button>
</section>
{{/each}}
</div>
{{/if}}

{{#if system.derived.hasTurnUndead}}
<div class="tab" data-group="primary" data-tab="cleric">
<hr>

<h2>Turn Undead (Derived)</h2>
<table>
  <thead>
    <tr>
      <th>Target</th>
      <th>Score</th>
    </tr>
  </thead>
  <tbody>
    {{#each turnUndeadList}}
    <tr>
      <td>{{this.target}}</td>
      <td>{{this.score}}</td>
    </tr>
    {{/each}}
  </tbody>
</table>
</div>
{{/if}}

 </section>

</form>

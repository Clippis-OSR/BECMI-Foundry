<form class="{{cssClass}}" autocomplete="off">

  <h1>{{actor.name}}</h1>

<nav class="sheet-tabs tabs" data-group="primary">
  <a class="item active" data-tab="main">Main</a>
  <a class="item" data-tab="combat">Combat</a>
  <a class="item" data-tab="equipment">Equipment</a>
  <a class="item" data-tab="skills">Skills</a>
  <a class="item" data-tab="magic">Magic</a>
  <a class="item" data-tab="cleric">Cleric</a>
</nav>

<section class="sheet-body">

<div class="tab active" data-group="primary" data-tab="main"></div>

<div class="tab" data-group="primary" data-tab="main">
  <h2>Details</h2>
  <div>Class: <input type="text" name="system.class" value="{{system.class}}" /></div>
  <div>Level: <input type="number" name="system.level" value="{{system.level}}" /></div>
  <div>XP: <input type="number" name="system.details.xp" value="{{system.details.xp}}" /></div>
  <div>Alignment: <input type="text" name="system.details.alignment" value="{{system.details.alignment}}" /></div>

  <hr>

  <h2>Abilities</h2>

<div>
  <button type="button" class="roll-ability" data-ability="str" data-label="Strength">Roll</button>
  STR:
  <input type="number" name="system.abilities.str.value" value="{{system.abilities.str.value}}" />
  / Mod:
  <input type="number" name="system.abilities.str.mod" value="{{system.abilities.str.mod}}" />
</div>

<div>
  <button type="button" class="roll-ability" data-ability="int" data-label="Intelligence">Roll</button>
  INT:
  <input type="number" name="system.abilities.int.value" value="{{system.abilities.int.value}}" />
  / Mod:
  <input type="number" name="system.abilities.int.mod" value="{{system.abilities.int.mod}}" />
</div>

<div>
  <button type="button" class="roll-ability" data-ability="wis" data-label="Wisdom">Roll</button>
  WIS:
  <input type="number" name="system.abilities.wis.value" value="{{system.abilities.wis.value}}" />
  / Mod:
  <input type="number" name="system.abilities.wis.mod" value="{{system.abilities.wis.mod}}" />
</div>

<div>
  <button type="button" class="roll-ability" data-ability="dex" data-label="Dexterity">Roll</button>
  DEX:
  <input type="number" name="system.abilities.dex.value" value="{{system.abilities.dex.value}}" />
  / Mod:
  <input type="number" name="system.abilities.dex.mod" value="{{system.abilities.dex.mod}}" />
</div>

<div>
  <button type="button" class="roll-ability" data-ability="con" data-label="Constitution">Roll</button>
  CON:
  <input type="number" name="system.abilities.con.value" value="{{system.abilities.con.value}}" />
  / Mod:
  <input type="number" name="system.abilities.con.mod" value="{{system.abilities.con.mod}}" />
</div>

<div>
  <button type="button" class="roll-ability" data-ability="cha" data-label="Charisma">Roll</button>
  CHA:
  <input type="number" name="system.abilities.cha.value" value="{{system.abilities.cha.value}}" />
  / Mod:
  <input type="number" name="system.abilities.cha.mod" value="{{system.abilities.cha.mod}}" />
</div>
  <hr>

  <h2>Languages Known</h2>
  <textarea name="system.languages" rows="3">{{system.languages}}</textarea>

  <hr>

  <h2>Special Abilities</h2>
  <textarea name="system.specialAbilities" rows="5">{{system.specialAbilities}}</textarea>

  </div>
<div class="tab" data-group="primary" data-tab="combat">
  <hr>

<h2>Combat</h2>

<div>
  AC:
  <input type="number" name="system.combat.ac" value="{{system.combat.ac}}" />
</div>

<div>
  THAC0:
  <span>{{system.derived.thac0}}</span>
</div>

<div>
  Initiative Modifier:
  <input type="number" name="system.combat.initiative" value="{{system.combat.initiative}}" />
  <button type="button" class="roll-initiative">Roll Initiative</button>
</div>

<div>
  Wrestling Rating:
  <input type="number" name="system.combat.wrestlingRating" value="{{system.combat.wrestlingRating}}" />
</div>

<div>
  HP:
  <input type="number" name="system.hp.value" value="{{system.hp.value}}" />
  /
  <input type="number" name="system.hp.max" value="{{system.hp.max}}" />
</div>

<div>
  Wounds:
  <input type="number" name="system.hp.wounds" value="{{system.hp.wounds}}" />
</div>

<hr>

<h2>Attacks</h2>

<table>
  <thead>
    <tr>
      <th>Roll</th>
      <th>Name</th>
      <th>Attack Mod</th>
      <th>Damage</th>
      <th>Damage Mod</th>
      <th>Remove</th>
    </tr>
  </thead>
  <tbody>
    {{#each attacks as |attack index|}}
    <tr>
      <td>
        <button type="button" data-action="roll-character-attack" data-index="{{index}}">
          Attack
        </button>
      </td>
      <td>
        <input type="text" name="attack-name-{{index}}" value="{{attack.name}}" data-action="change-character-attack-field" data-index="{{index}}" data-field="name" />
      </td>
      <td>
        <input type="number" name="attack-mod-{{index}}" value="{{attack.attackMod}}" data-action="change-character-attack-field" data-index="{{index}}" data-field="attackMod" />
      </td>
      <td>
        <input type="text" name="attack-damage-{{index}}" value="{{attack.damage}}" data-action="change-character-attack-field" data-index="{{index}}" data-field="damage" />
      </td>
      <td>
        <input type="number" name="attack-damage-mod-{{index}}" value="{{attack.damageMod}}" data-action="change-character-attack-field" data-index="{{index}}" data-field="damageMod" />
      </td>
      <td>
        <button type="button" data-action="remove-character-attack" data-index="{{index}}">Remove</button>
      </td>
    </tr>
    {{/each}}
  </tbody>
</table>

<button type="button" data-action="add-character-attack">Add Attack</button>

<hr>

<h2>Saving Throws</h2>

<div>
  <button type="button" class="roll-save" data-save="death" data-label="Death Ray / Poison">
    Roll
  </button>
  Death Ray / Poison:
  <span>{{system.derived.saves.death}}</span>
</div>

<div>
  <button type="button" class="roll-save" data-save="wands" data-label="Magic Wands">
    Roll
  </button>
  Magic Wands:
  <span>{{system.derived.saves.wands}}</span>
</div>

<div>
  <button type="button" class="roll-save" data-save="paralysis" data-label="Paralysis / Turn to Stone">
    Roll
  </button>
  Paralysis / Turn to Stone:
  <span>{{system.derived.saves.paralysis}}</span>
</div>

<div>
  <button type="button" class="roll-save" data-save="breath" data-label="Dragon Breath">
    Roll
  </button>
  Dragon Breath:
  <span>{{system.derived.saves.breath}}</span>
</div>

<div>
  <button type="button" class="roll-save" data-save="spells" data-label="Rod, Staff, or Spell">
    Roll
  </button>
  Rod, Staff, or Spell:
  <span>{{system.derived.saves.spells}}</span>
</div>

<h2>Weapon Mastery</h2>

<table>
  <thead>
    <tr>
      <th>Weapon</th>
      <th>Level</th>
      <th>Damage</th>
      <th>Range</th>
      <th>Defense</th>
      <th>Special</th>
    </tr>
  </thead>
  <tbody>
    {{#each system.weaponMastery as |wm i|}}
    <tr>
      <td><input type="text" name="system.weaponMastery.{{i}}.weapon" value="{{wm.weapon}}" /></td>
      <td><input type="text" name="system.weaponMastery.{{i}}.level" value="{{wm.level}}" /></td>
      <td><input type="text" name="system.weaponMastery.{{i}}.damage" value="{{wm.damage}}" /></td>
      <td><input type="text" name="system.weaponMastery.{{i}}.range" value="{{wm.range}}" /></td>
      <td><input type="text" name="system.weaponMastery.{{i}}.defense" value="{{wm.defense}}" /></td>
      <td><input type="text" name="system.weaponMastery.{{i}}.special" value="{{wm.special}}" /></td>
    </tr>
    {{/each}}
  </tbody>
</table>
</div>

<div class="tab" data-group="primary" data-tab="skills">
<hr>

<h2>General Skill Mastery</h2>
<table>
  <thead>
    <tr>
      <th>Skill</th>
      <th>Ability</th>
      <th>Score</th>
      <th>Notes</th>
    </tr>
  </thead>
  <tbody>
    {{#each system.generalSkills as |skill i|}}
    <tr>
      <td><input type="text" name="system.generalSkills.{{i}}.name" value="{{skill.name}}" /></td>
      <td><input type="text" name="system.generalSkills.{{i}}.ability" value="{{skill.ability}}" /></td>
      <td><input type="number" name="system.generalSkills.{{i}}.score" value="{{skill.score}}" /></td>
      <td><input type="text" name="system.generalSkills.{{i}}.notes" value="{{skill.notes}}" /></td>
    </tr>
    {{/each}}
  </tbody>
</table>

    {{#if system.derived.hasThiefSkills}}
    <h2>Thief Skills</h2>

<div>
  <button type="button" class="roll-thief-skill" data-skill="openLocks" data-label="Open Locks">Roll</button>
  Open Locks:
  <span>{{system.derived.thiefSkills.openLocks}}</span> %
</div>

<div>
  <button type="button" class="roll-thief-skill" data-skill="findTraps" data-label="Find Traps">Roll</button>
  Find Traps:
  <span>{{system.derived.thiefSkills.findTraps}}</span> %
</div>

<div>
  <button type="button" class="roll-thief-skill" data-skill="removeTraps" data-label="Remove Traps">Roll</button>
  Remove Traps:
  <span>{{system.derived.thiefSkills.removeTraps}}</span> %
</div>

<div>
  <button type="button" class="roll-thief-skill" data-skill="climbWalls" data-label="Climb Walls">Roll</button>
  Climb Walls:
  <span>{{system.derived.thiefSkills.climbWalls}}</span> %
</div>

<div>
  <button type="button" class="roll-thief-skill" data-skill="moveSilently" data-label="Move Silently">Roll</button>
  Move Silently:
  <span>{{system.derived.thiefSkills.moveSilently}}</span> %
</div>

<div>
  <button type="button" class="roll-thief-skill" data-skill="hideInShadows" data-label="Hide in Shadows">Roll</button>
  Hide in Shadows:
  <span>{{system.derived.thiefSkills.hideInShadows}}</span> %
</div>

<div>
  <button type="button" class="roll-thief-skill" data-skill="pickPockets" data-label="Pick Pockets">Roll</button>
  Pick Pockets:
  <span>{{system.derived.thiefSkills.pickPockets}}</span> %
</div>

<div>
  <button type="button" class="roll-thief-skill" data-skill="hearNoise" data-label="Hear Noise">Roll</button>
  Hear Noise:
  <span>{{system.derived.thiefSkills.hearNoise}}</span> %
</div>
{{/if}}
</div>

<div class="tab" data-group="primary" data-tab="equipment">

<hr>

<h2>Coinage</h2>
<table>
  <thead>
    <tr>
      <th></th>
      <th>PP</th>
      <th>GP</th>
      <th>EP</th>
      <th>SP</th>
      <th>CP</th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td>Carried</td>
      <td><input type="number" name="system.coinage.carried.pp" value="{{system.coinage.carried.pp}}" /></td>
      <td><input type="number" name="system.coinage.carried.gp" value="{{system.coinage.carried.gp}}" /></td>
      <td><input type="number" name="system.coinage.carried.ep" value="{{system.coinage.carried.ep}}" /></td>
      <td><input type="number" name="system.coinage.carried.sp" value="{{system.coinage.carried.sp}}" /></td>
      <td><input type="number" name="system.coinage.carried.cp" value="{{system.coinage.carried.cp}}" /></td>
    </tr>
    <tr>
      <td>Treasure Hoard</td>
      <td><input type="number" name="system.coinage.hoard.pp" value="{{system.coinage.hoard.pp}}" /></td>
      <td><input type="number" name="system.coinage.hoard.gp" value="{{system.coinage.hoard.gp}}" /></td>
      <td><input type="number" name="system.coinage.hoard.ep" value="{{system.coinage.hoard.ep}}" /></td>
      <td><input type="number" name="system.coinage.hoard.sp" value="{{system.coinage.hoard.sp}}" /></td>
      <td><input type="number" name="system.coinage.hoard.cp" value="{{system.coinage.hoard.cp}}" /></td>
    </tr>
  </tbody>
</table>

<hr>

<h2>Treasure</h2>
<textarea name="system.treasure" rows="4">{{system.treasure}}</textarea>

<hr>

<h2>Encumbrance & Movement</h2>
<div>Total Encumbrance Carried:
  <input type="number" name="system.encumbrance.total" value="{{system.encumbrance.total}}" />
</div>
<div>Without Backpack:
  <input type="number" name="system.encumbrance.withoutBackpack" value="{{system.encumbrance.withoutBackpack}}" />
</div>
<div>Without Sack(s):
  <input type="number" name="system.encumbrance.withoutSacks" value="{{system.encumbrance.withoutSacks}}" />
</div>
<div>Only Belt Pouch & Items Worn:
  <input type="number" name="system.encumbrance.beltPouchAndWorn" value="{{system.encumbrance.beltPouchAndWorn}}" />
</div>
<div>Normal Speed:
  <input type="number" name="system.encumbrance.normalSpeed" value="{{system.encumbrance.normalSpeed}}" />
</div>
<div>Encounter Speed:
  <input type="number" name="system.encumbrance.encounterSpeed" value="{{system.encumbrance.encounterSpeed}}" />
</div>

<hr>

<h2>Equipment Containers</h2>

<h3>Items in Belt Pouch</h3>
<textarea name="system.containers.beltPouch.items" rows="4">{{system.containers.beltPouch.items}}</textarea>
<div>Enc:
  <input type="number" name="system.containers.beltPouch.enc" value="{{system.containers.beltPouch.enc}}" />
</div>

<h3>Items Worn</h3>
<textarea name="system.containers.worn.items" rows="4">{{system.containers.worn.items}}</textarea>
<div>Enc:
  <input type="number" name="system.containers.worn.enc" value="{{system.containers.worn.enc}}" />
</div>

<h3>Items in Backpack</h3>
<textarea name="system.containers.backpack.items" rows="6">{{system.containers.backpack.items}}</textarea>
<div>Enc:
  <input type="number" name="system.containers.backpack.enc" value="{{system.containers.backpack.enc}}" />
</div>

<h3>Items in Sack #1</h3>
<textarea name="system.containers.sack1.items" rows="5">{{system.containers.sack1.items}}</textarea>
<div>Enc:
  <input type="number" name="system.containers.sack1.enc" value="{{system.containers.sack1.enc}}" />
</div>

<h3>Items in Sack #2</h3>
<textarea name="system.containers.sack2.items" rows="5">{{system.containers.sack2.items}}</textarea>
<div>Enc:
  <input type="number" name="system.containers.sack2.enc" value="{{system.containers.sack2.enc}}" />
</div>

</div>

{{#if system.derived.hasSpellcasting}}
<div class="tab" data-group="primary" data-tab="magic">
<hr>

<h2>Spell Slots (Derived)</h2>
<pre>{{system.derived.spellSlots}}</pre>
</div>
{{/if}}

{{#if system.derived.hasTurnUndead}}
<div class="tab" data-group="primary" data-tab="cleric">
<hr>

<h2>Turn Undead (Derived)</h2>
<pre>{{system.derived.turnUndead}}</pre>
</div>
{{/if}}

 </section>

</form>

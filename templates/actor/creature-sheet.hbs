<form class="{{cssClass}} becmi sheet actor creature-sheet" autocomplete="off">
  <h1>BECMI Creature Sheet Loaded</h1>

  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="64" width="64"/>
    <input name="name" type="text" value="{{actor.name}}" placeholder="Name"/>
  </header>

  <section class="sheet-body">
    <label>Creature Role</label>
    <select name="system.creatureRole" data-action="change-creature-role">
      <option value="monster" {{creatureRoleSelected.monster}}>Monster</option>
      <option value="retainer" {{creatureRoleSelected.retainer}}>Retainer</option>
      <option value="npc" {{creatureRoleSelected.npc}}>NPC</option>
    </select>

    <h2>Core Stats</h2>

    <label>HD</label>
    <input type="text" name="system.hd" value="{{system.hd}}" data-action="change-creature-field"/>

    <label>HP</label>
    <input type="number" name="system.hp.value" value="{{system.hp.value}}" data-action="change-creature-field"/>

    <label>Max HP</label>
    <input type="number" name="system.hp.max" value="{{system.hp.max}}" data-action="change-creature-field"/>

    <label>AC (Base)</label>
    <input type="number" name="system.ac.base" value="{{system.ac.base}}" data-action="change-creature-field"/>

    <label>AC (Final)</label>
    <input type="number" name="system.ac.value" value="{{system.ac.value}}" readonly/>
    {{#if system.ac.breakdown.length}}<details><summary>AC Breakdown</summary><ul>{{#each system.ac.breakdown as |part|}}<li>{{part.label}} {{#if part.value}}: {{part.value}}{{/if}}{{#if part.modifier}} ({{part.modifier}}){{/if}}</li>{{/each}}</ul></details>{{/if}}

    <label>THAC0</label>
    <span>{{system.derived.thac0}}</span>

    <h2>Saving Throws</h2>
    <div>Death Ray / Poison: <span>{{system.saves.deathRayPoison.value}}</span></div>
    <div>Magic Wands: <span>{{system.saves.magicWands.value}}</span></div>
    <div>Paralysis / Turn to Stone: <span>{{system.saves.paralysisTurnStone.value}}</span></div>
    <div>Dragon Breath: <span>{{system.saves.dragonBreath.value}}</span></div>
    <div>Rod / Staff / Spell: <span>{{system.saves.rodStaffSpell.value}}</span></div>

    <label>Morale</label>
    <input type="number" name="system.morale" value="{{system.morale}}" data-action="change-creature-field"/>

    <label>Movement</label>
    <input type="text" name="system.movement" value="{{system.movement}}" data-action="change-creature-field"/>

    <label>Alignment</label>
    <input type="text" name="system.alignment" value="{{system.alignment}}" data-action="change-creature-field"/>

    <label>XP</label>
    <input type="number" name="system.xp" value="{{system.xp}}" data-action="change-creature-field"/>

    <label>Treasure Type</label>
    <input type="text" name="system.treasureType" value="{{system.treasureType}}" data-action="change-creature-field"/>

    <label>Number Appearing</label>
    <input type="text" name="system.numberAppearing" value="{{system.numberAppearing}}" data-action="change-creature-field"/>

    <label>Special Notes</label>
    <textarea name="system.specialNotes" data-action="change-creature-field">{{system.specialNotes}}</textarea>

    <h2>Save As</h2>

    <label>Save As Class</label>
    <select name="system.savesAs.class" data-action="change-creature-field">
      <option value="fighter" {{saveAsClassSelected.fighter}}>Fighter</option>
      <option value="cleric" {{saveAsClassSelected.cleric}}>Cleric</option>
      <option value="magic-user" {{saveAsClassSelected.magicUser}}>Magic-User</option>
      <option value="thief" {{saveAsClassSelected.thief}}>Thief</option>
      <option value="dwarf" {{saveAsClassSelected.dwarf}}>Dwarf</option>
      <option value="elf" {{saveAsClassSelected.elf}}>Elf</option>
      <option value="halfling" {{saveAsClassSelected.halfling}}>Halfling</option>
    </select>

    <label>Save As Level</label>
    <input type="number" name="system.savesAs.level" value="{{savesAs.level}}" data-action="change-creature-field"/>

    <h2>Attacks</h2>

    {{#each attacks as |attack index|}}
    <label>Attack Name</label>
    <input type="text" name="attack-name-{{index}}" value="{{attack.name}}" data-action="change-attack-field" data-index="{{index}}" data-field="name"/>

    <label>Attack Bonus</label>
    <input type="number" name="attack-bonus-{{index}}" value="{{attack.attackBonus}}" data-action="change-attack-field" data-index="{{index}}" data-field="attackBonus"/>

    <label>Damage</label>
    <input type="text" name="attack-damage-{{index}}" value="{{attack.damage}}" data-action="change-attack-field" data-index="{{index}}" data-field="damage"/>

    <button type="button" data-action="roll-creature-attack" data-index="{{index}}">Attack</button>
    <button type="button" data-action="remove-attack" data-index="{{index}}">Remove</button>
    {{/each}}

    <button type="button" data-action="add-attack">
      Add Attack
    </button>

  </section>
</form>

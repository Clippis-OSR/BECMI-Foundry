<form class="{{cssClass}} becmi sheet actor creature-sheet" autocomplete="off">
  <h1>BECMI Creature Sheet Loaded</h1>

  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="64" width="64"/>
    <input name="name" type="text" value="{{actor.name}}" placeholder="Name"/>
  </header>

  <section class="sheet-body">
    <label>Creature Role</label>
    <select name="system.creatureRole" data-action="change-creature-role">
      <option value="monster" {{creatureRoleSelected.monster}}>Monster</option>
      <option value="retainer" {{creatureRoleSelected.retainer}}>Retainer</option>
      <option value="npc" {{creatureRoleSelected.npc}}>NPC</option>
    </select>

    <h2>Core Stats</h2>

    <label>HD</label>
    <input type="text" name="system.hd" value="{{system.hd}}"/>

    <label>HP</label>
    <input type="number" name="system.hp.value" value="{{system.hp.value}}"/>

    <label>Max HP</label>
    <input type="number" name="system.hp.max" value="{{system.hp.max}}"/>

    <label>AC</label>
    <input type="number" name="system.ac" value="{{system.ac}}"/>

    <label>THAC0</label>
    <input type="number" name="system.thac0" value="{{system.thac0}}"/>

    <label>Morale</label>
    <input type="number" name="system.morale" value="{{system.morale}}"/>

    <label>Movement</label>
    <input type="text" name="system.movement" value="{{system.movement}}"/>

    <label>Alignment</label>
    <input type="text" name="system.alignment" value="{{system.alignment}}"/>

    <label>XP</label>
    <input type="number" name="system.xp" value="{{system.xp}}"/>

    <label>Treasure Type</label>
    <input type="text" name="system.treasureType" value="{{system.treasureType}}"/>

    <label>Number Appearing</label>
    <input type="text" name="system.numberAppearing" value="{{system.numberAppearing}}"/>

    <label>Special Notes</label>
    <textarea name="system.specialNotes">{{system.specialNotes}}</textarea>
  </section>
</form>

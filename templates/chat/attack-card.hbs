<div class="becmi-chat-card becmi-attack-card">
  <div class="becmi-chat-header"><strong>{{attackName}}</strong></div>
  <div>Attacker: {{attackerName}}</div>
  <div>Target: {{targetName}}</div>
  <div>d20 Result: {{d20}}</div>
  <div>Modifiers: {{modifiers}}</div>
  <div>Total Attack Roll: {{total}}</div>
  <div>Target AC: {{targetAC}}</div>
  <div>Required Roll: {{requiredRoll}}</div>

  <div class="becmi-chat-result {{#if hit}}becmi-hit{{else}}becmi-miss{{/if}}">
    {{#if hit}}HIT{{else}}MISS{{/if}}
  </div>

  {{#if hit}}
    {{#if damageResult}}
      <div class="becmi-damage">Damage: {{damageResult.total}}</div>
      {{#unless damageApplied}}
        <button type="button" class="becmi-apply-damage" data-action="apply-damage">Apply Damage</button>
      {{/unless}}
    {{/if}}
  {{/if}}
</div>

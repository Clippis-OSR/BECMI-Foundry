<form class="becmi-item-sheet" autocomplete="off">
  <header class="sheet-header">
    <h1><input type="text" name="name" value="{{item.name}}" placeholder="Item Name" /></h1>
    <p>Type: {{item.type}}</p>
  </header>

  <section class="sheet-body">
    <h2>Shared</h2>
    <div class="form-group"><label>Description</label><textarea name="system.description" rows="4">{{safeSystem.description}}</textarea></div>
    <div class="form-group"><label>Quantity</label><input type="number" name="system.quantity" value="{{safeSystem.quantity}}" step="1" /></div>
    <div class="form-group"><label>Stackable</label><input type="checkbox" name="system.stackable" {{checked safeSystem.stackable}} /></div>
    <div class="form-group"><label>Encumbrance (cn)</label><input type="number" name="system.weight" value="{{safeSystem.weight}}" step="0.01" /></div>
    <div class="form-group"><label>Value</label><input type="number" name="system.value" value="{{safeSystem.value}}" step="0.01" /></div>
    <div class="form-group"><label>Identified</label><input type="checkbox" name="system.identified" {{checked safeSystem.identified}} /></div>
        <div class="form-group"><label>Equipped</label><input type="checkbox" name="system.equipped" {{checked safeSystem.equipped}} /></div>
    <div class="form-group">
      <label>Equip Slot</label>
      <select name="system.slot">
        {{#if isArmor}}{{#each armorEquipSlotOptions as |slot|}}<option value="{{slot}}" {{#if (eq ../safeSystem.slot slot)}}selected{{/if}}>{{slot}}</option>{{/each}}{{else if isWeapon}}{{#each weaponEquipSlotOptions as |slot|}}<option value="{{slot}}" {{#if (eq ../safeSystem.slot slot)}}selected{{/if}}>{{slot}}</option>{{/each}}{{else}}{{#each equipSlotOptions as |slot|}}<option value="{{slot}}" {{#if (eq ../safeSystem.slot slot)}}selected{{/if}}>{{slot}}</option>{{/each}}{{/if}}
      </select>
    </div>
    <div class="form-group"><label>Tags (comma-separated)</label><input type="text" name="system.tagsString" value="{{tagsString}}" /></div>
    <div class="form-group"><label>Notes</label><textarea name="system.notes" rows="3">{{safeSystem.notes}}</textarea></div>

    {{#if isWeapon}}
      <h2>Weapon</h2>
            <div class="form-group"><label>Weapon</label><select name="system.weaponKey"><option value="custom">Custom</option>{{#each weaponOptions as |weapon|}}<option value="{{weapon.id}}" {{#if (eq ../safeSystem.weaponKey weapon.id)}}selected{{/if}}>{{weapon.label}}</option>{{/each}}</select></div>
      <div class="form-group"><label>Hands</label><select name="system.hands"><option value="none" {{#if (eq safeSystem.hands "none")}}selected{{/if}}>None</option><option value="one" {{#if (eq safeSystem.hands "one")}}selected{{/if}}>One</option><option value="two" {{#if (eq safeSystem.hands "two")}}selected{{/if}}>Two</option></select></div>
      <div class="form-group"><label>Damage</label><input type="text" name="system.damage" value="{{safeSystem.damage}}" /></div>
      <div class="form-group">
        <label>Weapon Type</label>
        <select name="system.weaponType">
          <option value="melee" {{#if (eq safeSystem.weaponType "melee")}}selected{{/if}}>Melee</option>
          <option value="missile" {{#if (eq safeSystem.weaponType "missile")}}selected{{/if}}>Missile</option>
          <option value="natural" {{#if (eq safeSystem.weaponType "natural")}}selected{{/if}}>Natural</option>
        </select>
      </div>
      <div class="form-group"><label>Damage Types</label><select name="system.damageTypes" multiple>{{selectOptions damageTypeOptions selected=safeSystem.damageTypes}}</select></div>
      {{#if (eq safeSystem.weaponType "missile")}}
      <div class="form-group"><label>Range Short</label><input type="number" name="system.range.short" value="{{safeSystem.range.short}}" step="1" /></div>
      <div class="form-group"><label>Range Medium</label><input type="number" name="system.range.medium" value="{{safeSystem.range.medium}}" step="1" /></div>
      <div class="form-group"><label>Range Long</label><input type="number" name="system.range.long" value="{{safeSystem.range.long}}" step="1" /></div>
      <div class="form-group"><label>Ammo Type</label><select name="system.ammoType"><option value="" {{#if (eq safeSystem.ammoType "")}}selected{{/if}}>None</option><option value="arrow" {{#if (eq safeSystem.ammoType "arrow")}}selected{{/if}}>Arrow</option><option value="quarrel" {{#if (eq safeSystem.ammoType "quarrel")}}selected{{/if}}>Quarrel</option><option value="slingStone" {{#if (eq safeSystem.ammoType "slingStone")}}selected{{/if}}>Sling Stone</option><option value="custom" {{#if (eq safeSystem.ammoType "custom")}}selected{{/if}}>Custom</option></select></div>
      {{/if}}
    {{/if}}

    {{#if isArmor}}
      <h2>Armor</h2>
      <div class="form-group">
        <label>Armor Type</label>
        <select name="system.armorType">
          {{#each armorTypeOptions as |armorType|}}
            <option value="{{armorType.key}}" {{#if (eq ../safeSystem.armorType armorType.key)}}selected{{/if}}>{{armorType.label}}</option>
          {{/each}}
        </select>
      </div>
      <div class="form-group"><label>Derived Base AC (descending)</label><input type="number" value="{{safeSystem.baseAC}}" readonly /></div>
      <div class="form-group"><label>Derived Shield AC Bonus</label><input type="number" value="{{safeSystem.acBonus}}" readonly /></div>
      <div class="form-group"><label>Derived Encumbrance</label><input type="number" value="{{safeSystem.weight}}" readonly /></div>
    {{/if}}

    {{#if isContainer}}
      <h2>Container</h2>
      <div class="form-group"><label>Capacity</label><input type="number" name="system.capacity" value="{{safeSystem.capacity}}" step="0.01" /></div>
      <div class="form-group"><label>Container Type</label><input type="text" name="system.containerType" value="{{safeSystem.containerType}}" /></div>
      <div class="form-group"><label>Contained Weight</label><input type="number" name="system.containedWeight" value="{{safeSystem.containedWeight}}" step="0.01" /></div>
      <div class="form-group"><label>Weight Reduction</label><input type="number" name="system.weightReduction" value="{{safeSystem.weightReduction}}" step="0.01" /></div>
      <div class="form-group"><label>Slots</label><input type="number" name="system.slots" value="{{safeSystem.slots}}" step="1" /></div>
    {{/if}}

    {{#if isCurrency}}
      <h2>Currency</h2>
      <div class="form-group"><label>Denomination</label><input type="text" name="system.denomination" value="{{safeSystem.denomination}}" /></div>
      <div class="form-group"><label>Exchange Value</label><input type="number" name="system.exchangeValue" value="{{safeSystem.exchangeValue}}" step="0.01" /></div>
      <div class="form-group"><label>Weight Per Unit</label><input type="number" name="system.weightPerUnit" value="{{safeSystem.weightPerUnit}}" step="0.01" /></div>
    {{/if}}

    {{#if isTreasure}}
      <h2>Treasure</h2>
      <div class="form-group"><label>Treasure Type</label><input type="text" name="system.treasureType" value="{{safeSystem.treasureType}}" /></div>
      <div class="form-group"><label>Estimated Value</label><input type="number" name="system.estimatedValue" value="{{safeSystem.estimatedValue}}" step="0.01" /></div>
    {{/if}}

    {{#if isAmmo}}
      <h2>Ammunition</h2>
      <div class="form-group"><label>Ammo Type</label><select name="system.ammoType">{{#each ammoTypeOptions as |atype|}}<option value="{{atype}}" {{#if (eq ../safeSystem.ammoType atype)}}selected{{/if}}>{{atype}}</option>{{/each}}</select></div>
      <div class="form-group"><label>Quantity</label><input type="number" name="system.quantity" value="{{safeSystem.quantity}}" step="1" /></div>
      <div class="form-group"><label>Encumbrance (cn)</label><input type="number" name="system.weight" value="{{safeSystem.weight}}" step="0.01" /></div>
      <div class="form-group"><label>Value</label><input type="number" name="system.value" value="{{safeSystem.value}}" step="0.01" /></div>
      <div class="form-group"><label>Damage Types</label><select name="system.damageTypes" multiple>{{selectOptions damageTypeOptions selected=safeSystem.damageTypes}}</select></div>
      <div class="form-group"><label>Notes</label><textarea name="system.notes" rows="3">{{safeSystem.notes}}</textarea></div>
    {{/if}}

    {{#if isConsumable}}
      <h2>Consumable</h2>
      <div class="form-group"><label>Uses</label><input type="number" name="system.uses" value="{{safeSystem.uses}}" step="1" /></div>
      <div class="form-group"><label>Max Uses</label><input type="number" name="system.maxUses" value="{{safeSystem.maxUses}}" step="1" /></div>
      <div class="form-group"><label>Consumed On Use</label><input type="checkbox" name="system.consumedOnUse" {{checked safeSystem.consumedOnUse}} /></div>
      <div class="form-group"><label>Effect Data</label><textarea name="system.effectData" rows="4">{{effectDataString}}</textarea></div>
    {{/if}}
  </section>
</form>
